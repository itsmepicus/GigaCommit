{
  "name": "gigacommit",
  "displayName": "GigaCommit - AI-Powered Git Commits",
  "publisher": "itsmepicus",
  "version": "1.0.0",

  "repository": {
    "type": "git",
    "url": "https://github.com/itsmepicus/gigacommit.git"
  },
  "description": "VSCode extension for AI-powered commits using GigaChat and Conventional Commits",
  "icon": "icon.png",
  "main": "out/extension.js",
  "activationEvents": [
    "onCommand:gigacommit.makeCommit"
  ],
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -p ./ --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext .ts",
    "test": "node ./out/test/runTest.js",
    "prepublishOnly": "npm run compile",
    "vscode:prepublish": "npm run compile"
  },
  "keywords": [
    "vscode",
    "extension",
    "ai",
    "commit",
    "gigachat",
    "conventional-commits"
  ],
  "author": {
    "name": "Igor Zarubin",
    "email": "Zarubin.kol2019@gmail.com"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "dependencies": {
    "@types/vscode": "^1.80.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^16.18.74",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.45.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "typescript": "^5.9.3"
  },
  "contributes": {
    "commands": [
      {
        "command": "gigacommit.makeCommit",
        "title": "Make AI Commit with GigaChat",
        "icon": {
          "light": "media/light/gigacommit.svg",
          "dark": "media/dark/gigacommit.svg"
        }
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "gigacommit.makeCommit",
          "when": "scmProvider == git",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "gigacommit.makeCommit",
          "when": "view == scm",
          "group": "navigation"
        }
      ],
      "scm/inputBox": [
        {
          "command": "gigacommit.makeCommit",
          "when": "scmProvider == git",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "GigaCommit Settings",
      "properties": {
        "gigacommit.authorizationKey": {
          "type": "string",
          "default": "",
          "description": "OAuth credential: paste your ClientID:ClientSecret string directly, or a Base64-encoded key"
        },
        "gigacommit.authUrl": {
          "type": "string",
          "default": "https://ngw.devices.sberbank.ru:9443/api/v2/oauth",
          "description": "OAuth token endpoint"
        },
        "gigacommit.apiBaseUrl": {
          "type": "string",
          "default": "https://api.giga.chat/v1",
          "description": "API base URL. Use https://gigachat.devices.sberbank.ru/api/v1 for personal license or https://api.giga.chat/v1 for B2B/B2C corporate"
        },
        "gigacommit.scope": {
          "type": "string",
          "enum": ["GIGACHAT_API_PERS", "GIGACHAT_API_B2B", "GIGACHAT_API_CORP"],
          "default": "GIGACHAT_API_PERS",
          "description": "OAuth scope: GIGACHAT_API_PERS (personal), GIGACHAT_API_B2B (B2B license), or GIGACHAT_API_CORP (corporate)"
        },
        "gigacommit.model": {
          "type": "string",
          "enum": ["GigaChat-2", "GigaChat-2-Pro", "GigaChat-2-Max"],
          "default": "GigaChat-2-Pro",
          "description": "GigaChat model to use. GigaChat-2 (standard), GigaChat-2-Pro (recommended), GigaChat-2-Max (most capable)"
        },
        "gigacommit.caBundlePath": {
          "type": "string",
          "default": "",
          "description": "Path to a PEM file containing trusted CA certificates (needed if your system doesn't trust the Sber/NUTS certificate chain)"
        }
      }
    }
  }
}
